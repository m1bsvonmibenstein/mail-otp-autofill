{
  "manifest_version": 3,
  "name": "Mail OTP Autofill",
  "version": "1.1.0",
  "description": "Surfaces verification codes from your webmail (mailcow/SOGo, and more) and offers one-click copy + autofill on any site.",
  "key": "",
  "permissions": ["storage", "notifications", "tabs", "scripting", "nativeMessaging", "alarms"],
  "optional_host_permissions": ["*://*/*"],
  "background": { "service_worker": "background.js", "scripts": ["background.js"] },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mail OTP Autofill",
    "default_icon": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
  },
  "icons": { "16": "icons/icon-16.png", "48": "icons/icon-48.png", "128": "icons/icon-128.png" },
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["toast.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "mail-otp-autofill@mibs",
      "strict_min_version": "128.0",
      "data_collection_permissions": { "required": ["none"] }
    }
  }
}
